# Public URL of your deployed worker
BRAIN_URL=https://your-brain.yourdomain.com

# Worker API auth key (set as Wrangler secret in production)
API_KEY=replace-with-a-long-random-secret

# Neon Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Default tenant used by scripts/tools
BRAIN_TENANT=rook

# Runtime wake script auth (usually same value as API_KEY)
BRAIN_API_KEY=replace-with-a-long-random-secret

# Optional runner defaults
WAKE_KIND=duty
TRIGGER_MODE=schedule
AUTO_CLAIM_TASK=true
ENFORCE_POLICY=true
EMIT_SKILL_CANDIDATE=true

# Comma-separated list of allowed CORS origins (used by the Worker)
CORS_ORIGINS=https://your-app.example.com
