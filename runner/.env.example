# ============================================
# Provider selection (run.sh)
# ============================================
# auto: claude (if logged in) -> codex (if logged in) -> anthropic_api (if key set)
RUNNER_PROVIDER=auto

# Subscription CLI provider settings
CLAUDE_MODEL=claude-sonnet-4-20250514
CODEX_MODEL=gpt-5.4
CODEX_SANDBOX=read-only
# Optional Codex profile (e.g. openrouter profile if configured in codex)
# CODEX_PROFILE=openrouter

# ============================================
# API mode (node dist/index.js / npm start)
# ============================================
# Required for anthropic_api provider
ANTHROPIC_API_KEY=sk-ant-...

# Brain connection
BRAIN_URL=https://rook.funkatorium.org/mcp
BRAIN_API_KEY=your-brain-api-key-here
TENANT_ID=rook

# Model alias for API mode
MODEL=claude-sonnet-4-20250514

# Execution limits (API mode)
MAX_ITERATIONS=25
MAX_TOKENS=4096
MAX_REPAIRS=1
STAGE_TIMEOUT_MS=120000
ENABLE_SELF_IMPROVEMENT=false
PROPOSAL_REVIEW_LIMIT=10
PROPOSAL_ACCEPT_THRESHOLD=0.85

# Schedule (node-cron format) — default: 6am, 12pm, 6pm daily
SCHEDULE=0 6,12,18 * * *

# Audit trail
AUDIT_PATH=./audit.jsonl
ARTIFACT_DIR=./artifacts

# Optional: path to a custom system prompt text file
# SYSTEM_PROMPT_PATH=./system-prompt.txt

# Harness runtime: path to agent harness markdown file
HARNESS_AGENT_PATH=./harness/rainer.md
