# ============================================
# Provider selection (run.sh)
# ============================================
# auto: claude (if logged in) -> codex (if logged in) -> anthropic_api (if key set)
RUNNER_PROVIDER=auto

# Subscription CLI provider settings
CLAUDE_MODEL=claude-sonnet-4-20250514
CODEX_MODEL=gpt-5.4
# Leave unset to allow executor mode to switch to workspace-write for artifact wakes.
CODEX_SANDBOX=
# Optional Codex profile (e.g. openrouter profile if configured in codex)
# CODEX_PROFILE=openrouter

# ============================================
# API mode (node dist/index.js / npm start)
# ============================================
# Required for anthropic_api provider
ANTHROPIC_API_KEY=sk-ant-...

# Brain connection
BRAIN_URL=https://<your-worker-url>/mcp
BRAIN_API_KEY=your-brain-api-key-here
TENANT_ID=rainer

# Model alias for API mode
MODEL=claude-sonnet-4-20250514

# Execution limits (API mode)
MAX_ITERATIONS=25
MAX_TOKENS=4096
MAX_REPAIRS=1
STAGE_TIMEOUT_MS=120000
ENABLE_SELF_IMPROVEMENT=false
PROPOSAL_REVIEW_LIMIT=10
PROPOSAL_ACCEPT_THRESHOLD=0.85

# Schedule (node-cron format) — default: 6am, 12pm, 6pm daily
SCHEDULE=0 6,12,18 * * *

# ============================================
# Mac orchestrator mode (node dist/index.js --orchestrator)
# ============================================
# Copy ./config/tenants.example.json to ./config/tenants.json (gitignored), or point this at your own local config path.
TENANT_CONFIG_PATH=./config/tenants.json
ORCHESTRATOR_STATE_PATH=./state/orchestrator-state.json
ORCHESTRATOR_TIMEZONE=Europe/Berlin
ORCHESTRATOR_SLOT_GRACE_MINUTES=10
ORCHESTRATOR_MAX_DUTY_PASSES=8

# Optional Telegram notifier adapter
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_VOICE_ENABLED=false
# TELEGRAM_VOICE_REQUIRED=false
# VOICE_TTS_URL=https://<your-muse-tts-endpoint>/synthesize
# VOICE_TTS_API_KEY=
# VOICE_TTS_TIMEOUT_MS=20000
# VOICE_PERSONA_DEFAULT=lewis
# VOICE_PERSONA_RAINER=lewis
# VOICE_PERSONA_COMPANION=onyx

# Optional Telegram voice transcription bridge (npm run voice-bridge)
# VOICE_STT_URL=https://<your-whisper-endpoint>/v1/audio/transcriptions
# VOICE_STT_API_KEY=
# VOICE_STT_MODEL=whisper-1
# VOICE_BRIDGE_TENANT=rainer
# VOICE_BRIDGE_POLL_SECONDS=12
# VOICE_BRIDGE_TIMEOUT_MS=30000
# VOICE_BRIDGE_SEND_ACK=true
# VOICE_BRIDGE_STATE_PATH=./state/telegram-voice-bridge.json

# Local faster-whisper sidecar option:
#   npm run stt:faster-whisper
#   VOICE_STT_URL=http://127.0.0.1:8788/v1/audio/transcriptions
#   VOICE_STT_API_KEY=<same as FW_API_KEY if enabled>
#   VOICE_STT_MODEL=small

# Audit trail
AUDIT_PATH=./audit.jsonl
ARTIFACT_DIR=./artifacts

# Optional: path to a custom system prompt text file
# SYSTEM_PROMPT_PATH=./system-prompt.txt

# Harness runtime: path to agent harness markdown file
HARNESS_AGENT_PATH=./harness/rainer.md
