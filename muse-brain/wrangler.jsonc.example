/**
 * Copy to wrangler.jsonc and adjust values for your deployment.
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "muse-brain",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "observability": { "enabled": true },
  "triggers": { "crons": ["0 3 * * *"] },
  "ai": { "binding": "AI" },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "replace-with-your-hyperdrive-id"
    }
  ]
}
